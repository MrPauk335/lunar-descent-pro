rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - playerName: string (required, length 1-20) - The name entered by the player
    //   - score: number (required, >= 0) - The score achieved
    //   - difficulty: string (required, in ['easy', 'medium', 'hard']) - The difficulty level played
    //   - timestamp: timestamp (required) - When the score was achieved
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "meganeirosin@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidLeaderboardEntry(data) {
      return hasOnlyAllowedFields(['playerName', 'score', 'difficulty', 'timestamp']) &&
             hasRequiredFields(['playerName', 'score', 'difficulty', 'timestamp']) &&
             data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.difficulty in ['easy', 'medium', 'hard'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard_v3/{entryId} {
      // Allow public read for the leaderboard
      allow read: if true;
      
      // Allow public create with strict validation to prevent abuse
      allow create: if isValidLeaderboardEntry(request.resource.data);
      
      // Allow update for summing scores (player name must match)
      allow update: if isValidLeaderboardEntry(request.resource.data) && request.resource.data.playerName == resource.data.playerName;

      // Allow admin to delete
      allow delete: if isAdmin();
    }

    match /players/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
